{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sponsors",
  "description": "Schema for claude-adhd sponsor data",
  "type": "object",
  "required": ["version", "updated", "sponsors"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer"
    },
    "updated": {
      "type": "string"
    },
    "sponsors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tier", "since"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 20
          },
          "tier": {
            "type": "string",
            "enum": ["bronze", "silver", "gold"]
          },
          "text": {
            "type": "string",
            "maxLength": 30
          },
          "url": {
            "type": "string"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}$"
          }
        }
      }
    }
  }
}
